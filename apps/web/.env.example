# Verity web — environment contract
#
# Supabase auth (optional). Set BOTH to gate the app behind sign-in; leave the
# URL unset for local dev (no auth wall, gateway issues a dev-user).
#   - The anon key is a PUBLISHABLE key and safe to ship to the browser.
#   - NEVER put the Supabase service-role key in this file or the frontend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gateway origin for production (static export). In `next dev`, /gw is proxied
# to the local Go gateway, so this is not needed for local development.
# NEXT_PUBLIC_GATEWAY_URL=https://gateway.example.com

# Force the in-memory mock adapter for offline UI work (persistence, offices,
# keys, transcripts). Chat and flows always stream live.
# NEXT_PUBLIC_VERITY_MOCK=1
