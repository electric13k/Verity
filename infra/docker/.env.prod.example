# Verity v2 — production env template (Stage B/C).
# Copy to infra/docker/.env.prod and fill in. PLACEHOLDERS ONLY here — never
# commit real secrets. Secrets are user-supplied (plan law); agents never
# fetch or invent them. Every value is optional: the stack boots degraded and
# /healthz reports what is missing.
#
#   cp infra/docker/.env.prod.example infra/docker/.env.prod
#   docker compose -f infra/docker/compose.prod.yaml --env-file infra/docker/.env.prod up -d

# ---- images / publish ----------------------------------------------------
VERITY_TAG=latest
# Host bind for the gateway's only published port. Use 127.0.0.1 when a
# cloudflared sidecar fronts it; 0.0.0.0 when an external LB does.
GATEWAY_BIND=0.0.0.0
GATEWAY_PORT=8080

# ---- gateway: Clerk auth (public net has egress to fetch JWKS) ------------
CLERK_JWKS_URL=
CLERK_ISSUER=
# Comma-separated allowed browser origins (azp claim check), e.g.
# https://app.verity.example
VERITY_ALLOWED_ORIGINS=

# ---- data plane endpoints -------------------------------------------------
# Managed (Stage B) OR the in-compose services (--profile data). For the
# in-compose Postgres, DATABASE_URL host is `postgres`, e.g.
# postgres://verity:REPLACE_ME@postgres:5432/verity?sslmode=disable
# For a Supabase transaction pooler use the ...pooler.supabase.com:6543 host
# with ?sslmode=require (the brain pool disables prepared-statement caching).
DATABASE_URL=
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
COGNEE_URL=

# ---- brain: secrets & memory ---------------------------------------------
# AES-256-GCM key for user provider keys at rest (32 bytes; supply base64/hex
# per app expectation). SECRET — placeholder only.
ENCRYPTION_KEY=
# House models (env-gated). SECRET — placeholder only.
OLLAMA_CLOUD_API_KEY=
# cognee (PRIMARY memory) toggle + its own LLM. 1 to enable; needs the image's
# cognee extra installed. COGNEE_LLM_API_KEY is a SECRET — placeholder only.
VERITY_COGNEE=0
COGNEE_LLM_PROVIDER=
COGNEE_LLM_MODEL=
COGNEE_LLM_API_KEY=

# ---- self-hosted Postgres (only used with --profile data) -----------------
POSTGRES_USER=verity
# REQUIRED when running --profile data. Choose a strong value; not a real
# secret here — this file is a template.
POSTGRES_PASSWORD=
POSTGRES_DB=verity

# ---- compute node daemon (M7, --profile compute) --------------------------
VERITY_OWNER_ID=
OLLAMA_HOST=
NODE_NAME=verity-node
COORDINATOR_GRPC_ADDR=http://core:9200
